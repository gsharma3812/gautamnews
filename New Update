<div class="page-wrap">
  <main id="main-content">

    <!-- HOME -->
    <div class="content-section active" id="sec-home">
      <div class="state-notice" id="state-notice-main"></div>
      <div class="sec-title"><h2>Hourly Updates</h2><div class="pill-tag">Live</div><div class="sec-line"></div></div>

      <div class="hour-group">
        <div class="hour-stamp"><div class="hour-chip now" id="curHourChip">12:00 PM</div><div class="hour-line"></div><div class="hour-new">● Latest</div></div>
        <div class="news-card breaking anim" data-state="National" style="animation-delay:.04s">
          <div class="card-top"><span class="cat-tag red">Breaking</span><span class="breaking-flag">Breaking News</span></div>
          <h3>Parliament passes landmark Digital India Infrastructure Bill with 321 votes in favour</h3>
          <p>The bill allocates ₹2.4 lakh crore over 3 years to bring fibre broadband to 6 lakh villages by 2027.</p>
          <div class="card-meta"><span>🕐 12:45 PM</span><span>📍 New Delhi</span></div>
        </div>
        <div class="news-card anim" data-state="National" style="animation-delay:.09s">
          <div class="card-top"><span class="cat-tag">Economy</span></div>
          <h3>RBI keeps repo rate unchanged at 6.5% for sixth consecutive meeting, hints at June cut</h3>
          <p>MPC cites easing inflation and stable reserves; growth forecast upgraded to 7.2% for FY26.</p>
          <div class="card-meta"><span>🕐 12:20 PM</span><span>📍 Mumbai</span></div>
        </div>
        <div class="news-card anim" data-state="National" style="animation-delay:.14s">
          <div class="card-top"><span class="cat-tag yellow">Sports</span></div>
          <h3>India retains No. 1 Test ranking after historic 3–1 series win over Australia in Sydney</h3>
          <p>Jasprit Bumrah finishes with 32 wickets in the series — a record for any Indian fast bowler on Australian soil.</p>
          <div class="card-meta"><span>🕐 12:05 PM</span><span>📍 Sydney</span></div>
        </div>
      </div>

      <div class="hour-group">
        <div class="hour-stamp"><div class="hour-chip">11:00 AM</div><div class="hour-line"></div></div>
        <div class="news-card anim" data-state="Delhi" style="animation-delay:.05s">
          <div class="card-top"><span class="cat-tag blue">Delhi</span></div>
          <h3>Delhi government unveils ₹8,500 crore metro phase-IV expansion plan connecting 27 new stations</h3>
