<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gautam News Channel — India's Fastest News</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@700;900&family=DM+Sans:wght@300;400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet">
<style>
:root {
  --saffron: #FF6B00;
  --green: #138808;
  --navy: #07090F;
  --navy2: #0F1523;
  --navy3: #1A2035;
  --card: #141926;
  --border: rgba(255,255,255,0.07);
  --text: #E8EAF0;
  --muted: #6B7280;
  --muted2: #9CA3AF;
  --white: #FFFFFF;
  --red: #EF4444;
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }
body { font-family: 'DM Sans', sans-serif; background: var(--navy); color: var(--text); overflow-x: hidden; min-height: 100vh; }

.ticker-bar { background: var(--saffron); padding: 7px 0; overflow: hidden; position: relative; }
.ticker-bar::before, .ticker-bar::after { content:''; position:absolute; top:0; bottom:0; width:60px; z-index:2; }
.ticker-bar::before { left:0; background:linear-gradient(to right, var(--saffron), transparent); }
.ticker-bar::after  { right:0; background:linear-gradient(to left, var(--saffron), transparent); }
.ticker-inner { display:inline-block; white-space:nowrap; animation:scroll-ticker 50s linear infinite; font-size:0.75rem; font-weight:600; letter-spacing:0.06em; color:#fff; }
@keyframes scroll-ticker { 0%{transform:translateX(100vw)} 100%{transform:translateX(-100%)} }

header { background:var(--navy2); border-bottom:1px solid var(--border); position:sticky; top:0; z-index:200; }
.header-wrap { max-width:1280px; margin:0 auto; padding:0 24px; display:flex; align-items:center; justify-content:space-between; height:64px; gap:20px; }
.logo { display:flex; align-items:center; gap:10px; text-decoration:none; flex-shrink:0; }
.logo-icon { width:36px; height:36px; background:var(--saffron); border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; font-weight:900; color:white; font-family:'Fraunces',serif; }
.logo-text { font-family:'Fraunces',serif; font-size:1.4rem; font-weight:900; color:var(--white); letter-spacing:-0.02em; }
.logo-text span { color:var(--saffron); }
.live-badge { display:flex; align-items:center; gap:6px; font-size:0.65rem; font-weight:700; letter-spacing:0.12em; color:var(--red); text-transform:uppercase; }
.live-dot { width:7px; height:7px; background:var(--red); border-radius:50%; animation:blink 1.2s ease infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }
.clock-display { font-family:'Bebas Neue',sans-serif; font-size:1.3rem; color:var(--white); letter-spacing:0.08em; }
.clock-display .seconds { color:var(--saffron); }

.cat-nav { background:var(--navy3); border-bottom:1px solid var(--border); position:sticky; top:64px; z-index:150; }
.cat-nav-inner { max-width:1280px; margin:0 auto; padding:0 24px; display:flex; gap:2px; overflow-x:auto; scrollbar-width:none; }
.cat-nav-inner::-webkit-scrollbar { display:none; }
.cat-tab { flex-shrink:0; padding:14px 18px; font-size:0.8rem; font-weight:600; letter-spacing:0.04em; color:var(--muted2); cursor:pointer; border:none; background:none; font-family:'DM Sans',sans-serif; border-bottom:3px solid transparent; transition:all 0.22s; display:flex; align-items:center; gap:6px; white-space:nowrap; }
.cat-tab:hover { color:var(--white); }
.cat-tab.active { color:var(--saffron); border-bottom-color:var(--saffron); }

.state-bar { background:rgba(255,255,255,0.03); border-bottom:1px solid var(--border); padding:10px 0; }
.state-bar-inner { max-width:1280px; margin:0 auto; padding:0 24px; display:flex; gap:8px; overflow-x:auto; scrollbar-width:none; align-items:center; }
.state-bar-inner::-webkit-scrollbar { display:none; }
.state-label { font-size:0.65rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); white-space:nowrap; margin-right:4px; }
.state-pill { flex-shrink:0; padding:5px 14px; background:var(--navy3); border:1px solid var(--border); border-radius:100px; font-size:0.73rem; font-weight:500; color:var(--muted2); cursor:pointer; transition:all 0.2s; white-space:nowrap; font-family:'DM Sans',sans-serif; }
.state-pill:hover { background:rgba(255,107,0,0.12); border-color:rgba(255,107,0,0.4); color:var(--saffron); }
.state-pill.active { background:var(--saffron); border-color:var(--saffron); color:white; font-weight:700; box-shadow:0 0 16px rgba(255,107,0,0.35); }

.state-notice { display:none; background:rgba(255,107,0,0.08); border:1px solid rgba(255,107,0,0.2); border-radius:10px; padding:12px 18px; margin-bottom:16px; font-size:0.82rem; color:var(--saffron); font-weight:600; }
.state-notice.show { display:block; }

.page-wrap { max-width:1280px; margin:0 auto; padding:28px 24px; display:grid; grid-template-columns:1fr 320px; gap:28px; }

.sec-title { display:flex; align-items:center; gap:12px; margin-bottom:18px; }
.sec-title h2 { font-family:'Fraunces',serif; font-size:1.25rem; font-weight:700; color:var(--white); letter-spacing:-0.01em; }
.pill-tag { font-size:0.6rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; padding:3px 9px; border-radius:100px; background:rgba(255,107,0,0.15); color:var(--saffron); border:1px solid rgba(255,107,0,0.3); }
.pill-tag.green { background:rgba(19,136,8,0.15); color:#4ADE80; border-color:rgba(19,136,8,0.3); }
.pill-tag.blue { background:rgba(96,165,250,0.12); color:#60A5FA; border-color:rgba(96,165,250,0.3); }
.pill-tag.yellow { background:rgba(251,191,36,0.12); color:#FBB724; border-color:rgba(251,191,36,0.3); }
.pill-tag.purple { background:rgba(167,139,250,0.12); color:#A78BFA; border-color:rgba(167,139,250,0.3); }
.sec-line { flex:1; height:1px; background:var(--border); }

.hour-group { margin-bottom:30px; }
.hour-stamp { display:flex; align-items:center; gap:10px; margin-bottom:14px; }
.hour-chip { font-family:'Bebas Neue',sans-serif; font-size:0.95rem; letter-spacing:0.1em; padding:4px 14px; border-radius:6px; background:var(--navy3); color:var(--saffron); border:1px solid rgba(255,107,0,0.25); }
.hour-chip.now { background:var(--saffron); color:white; border-color:transparent; box-shadow:0 0 18px rgba(255,107,0,0.4); }
.hour-line { flex:1; height:1px; background:var(--border); }
.hour-new { font-size:0.6rem; font-weight:700; letter-spacing:.1em; color:var(--red); text-transform:uppercase; }

.news-card { background:var(--card); border:1px solid var(--border); border-radius:12px; padding:16px 18px; margin-bottom:10px; cursor:pointer; transition:all 0.22s cubic-bezier(.4,0,.2,1); position:relative; overflow:hidden; }
.news-card::before { content:''; position:absolute; left:0; top:0; bottom:0; width:3px; background:transparent; transition:background 0.2s; }
.news-card:hover { border-color:rgba(255,107,0,0.3); background:rgba(255,107,0,0.05); transform:translateY(-2px); box-shadow:0 8px 32px rgba(0,0,0,0.3); }
.news-card:hover::before { background:var(--saffron); }
.news-card.breaking::before { background:var(--red); }
.news-card.breaking { border-color:rgba(239,68,68,0.25); }
.card-top { display:flex; align-items:center; gap:8px; margin-bottom:8px; flex-wrap:wrap; }
.cat-tag { font-size:0.58rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; padding:3px 9px; border-radius:4px; background:rgba(255,107,0,0.15); color:var(--saffron); }
.cat-tag.red { background:rgba(239,68,68,0.15); color:var(--red); }
.cat-tag.green { background:rgba(74,222,128,0.1); color:#4ADE80; }
.cat-tag.blue { background:rgba(96,165,250,0.12); color:#60A5FA; }
.cat-tag.purple { background:rgba(167,139,250,0.12); color:#A78BFA; }
.cat-tag.yellow { background:rgba(251,191,36,0.12); color:#FBB724; }
.breaking-flag { font-size:0.58rem; font-weight:800; letter-spacing:0.15em; text-transform:uppercase; color:var(--red); display:flex; align-items:center; gap:4px; }
.breaking-flag::before { content:''; width:6px; height:6px; background:var(--red); border-radius:50%; animation:blink 0.8s infinite; }
.news-card h3 { font-family:'Fraunces',serif; font-size:1rem; font-weight:700; line-height:1.45; color:var(--white); margin-bottom:6px; letter-spacing:-0.01em; }
.news-card p { font-size:0.82rem; color:var(--muted2); line-height:1.6; margin-bottom:10px; }
.card-meta { display:flex; align-items:center; gap:12px; font-size:0.68rem; color:var(--muted); flex-wrap:wrap; }

.digest-wrap { background:linear-gradient(135deg,#0F1A2E 0%,#1A1030 100%); border:1px solid rgba(255,107,0,0.2); border-radius:16px; padding:26px; position:relative; overflow:hidden; margin-bottom:28px; }
.digest-wrap::after { content:'॥'; position:absolute; right:-10px; bottom:-20px; font-size:9rem; color:rgba(255,107,0,0.04); font-family:serif; }
.digest-edition { font-size:0.65rem; font-weight:700; letter-spacing:0.15em; color:var(--saffron); text-transform:uppercase; margin-bottom:18px; display:flex; align-items:center; gap:8px; }
.digest-edition::before { content:''; flex:0 0 16px; height:2px; background:var(--saffron); border-radius:1px; }
.digest-item { display:flex; gap:14px; padding:13px 0; border-bottom:1px solid rgba(255,255,255,0.05); cursor:pointer; transition:all 0.18s; }
.digest-item:last-child { border-bottom:none; padding-bottom:0; }
.digest-item:hover .digest-n { color:var(--saffron); }
.digest-n { font-family:'Bebas Neue',sans-serif; font-size:1.5rem; color:rgba(255,107,0,0.3); min-width:30px; line-height:1; transition:color 0.2s; }
.digest-text h4 { font-size:0.88rem; font-weight:600; color:var(--white); margin-bottom:3px; line-height:1.4; }
.digest-text p { font-size:0.77rem; color:var(--muted2); line-height:1.55; }

.sidebar { display:flex; flex-direction:column; gap:20px; }
.widget { background:var(--card); border:1px solid var(--border); border-radius:14px; overflow:hidden; }
.widget-head { padding:12px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
.widget-head h3 { font-size:0.78rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--white); display:flex; align-items:center; gap:7px; }
.widget-body { padding:16px 18px; }

.nl-widget { background:linear-gradient(135deg,#1A0A00,#2D1500); border:1px solid rgba(255,107,0,0.3); border-radius:14px; padding:22px 20px; position:relative; overflow:hidden; }
.nl-widget::before { content:'✉'; position:absolute; right:-12px; top:-8px; font-size:6rem; opacity:0.06; }
.nl-widget h3 { font-family:'Fraunces',serif; font-size:1.1rem; font-weight:700; color:var(--white); margin-bottom:6px; }
.nl-widget p { font-size:0.78rem; color:var(--muted2); margin-bottom:16px; line-height:1.55; }
.nl-input { width:100%; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.1); border-radius:8px; padding:10px 14px; font-size:0.82rem; color:var(--white); font-family:'DM Sans',sans-serif; outline:none; margin-bottom:8px; transition:border-color 0.2s; }
.nl-input::placeholder { color:var(--muted); }
.nl-input:focus { border-color:var(--saffron); }
.nl-btn { width:100%; background:var(--saffron); color:white; border:none; border-radius:8px; padding:11px; font-size:0.8rem; font-weight:700; letter-spacing:0.06em; cursor:pointer; font-family:'DM Sans',sans-serif; transition:all 0.2s; box-shadow:0 4px 20px rgba(255,107,0,0.3); }
.nl-btn:hover { background:#FF8C30; transform:translateY(-1px); }
.nl-success { display:none; text-align:center; padding:10px; background:rgba(74,222,128,0.12); border:1px solid rgba(74,222,128,0.3); border-radius:8px; font-size:0.8rem; font-weight:600; color:#4ADE80; margin-top:8px; }

.trend-item { display:flex; align-items:flex-start; gap:12px; padding:11px 0; border-bottom:1px solid var(--border); cursor:pointer; transition:all 0.18s; }
.trend-item:last-child { border-bottom:none; padding-bottom:0; }
.trend-item:hover .trend-title { color:var(--saffron); }
.trend-n { font-family:'Bebas Neue',sans-serif; font-size:1.3rem; color:rgba(255,107,0,0.4); min-width:24px; line-height:1.1; }
.trend-title { font-size:0.82rem; font-weight:600; color:var(--text); line-height:1.4; margin-bottom:2px; transition:color 0.18s; }
.trend-sub { font-size:0.65rem; color:var(--muted); }

.wx-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
.wx-card { background:rgba(255,255,255,0.04); border:1px solid var(--border); border-radius:10px; padding:10px 12px; text-align:center; }
.wx-city { font-size:0.65rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--muted2); margin-bottom:4px; }
.wx-temp { font-family:'Bebas Neue',sans-serif; font-size:1.6rem; color:var(--white); line-height:1; }
.wx-desc { font-size:0.62rem; color:var(--muted); margin-top:2px; }

.mkt-row { display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid var(--border); }
.mkt-row:last-child { border-bottom:none; padding-bottom:0; }
.mkt-name { font-size:0.82rem; font-weight:600; color:var(--white); }
.mkt-sub { font-size:0.65rem; color:var(--muted); margin-top:1px; }
.mkt-val { font-family:'Bebas Neue',sans-serif; font-size:1.05rem; color:var(--white); text-align:right; }
.mkt-chg { font-size:0.7rem; font-weight:700; text-align:right; }
.up { color:#4ADE80; } .dn { color:#F87171; }

.content-section { display:none; }
.content-section.active { display:block; }

@keyframes fadeSlide { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
.anim { animation:fadeSlide 0.35s ease both; }

footer { background:var(--navy2); border-top:1px solid var(--border); margin-top:20px; padding:40px 24px 24px; }
.footer-inner { max-width:1280px; margin:0 auto; }
.footer-top { display:flex; justify-content:space-between; gap:32px; margin-bottom:36px; flex-wrap:wrap; }
.footer-brand .fb-logo { font-family:'Fraunces',serif; font-size:1.6rem; font-weight:900; color:var(--white); margin-bottom:6px; }
.footer-brand .fb-logo span { color:var(--saffron); }
.footer-brand p { font-size:0.78rem; color:var(--muted); max-width:220px; line-height:1.6; margin-top:6px; }
.footer-col h4 { font-size:0.7rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:var(--muted2); margin-bottom:14px; }
.footer-col a { display:block; font-size:0.8rem; color:var(--muted); text-decoration:none; margin-bottom:8px; transition:color 0.18s; cursor:pointer; }
.footer-col a:hover { color:var(--saffron); }
.footer-bottom { border-top:1px solid var(--border); padding-top:18px; display:flex; justify-content:space-between; align-items:center; font-size:0.72rem; color:var(--muted); flex-wrap:wrap; gap:8px; }
.tricolor { height:3px; background:linear-gradient(to right, #FF6B00 33.3%, #ffffff 33.3% 66.6%, #138808 66.6%); }

.empty-state { text-align:center; padding:60px 20px; color:var(--muted); }
.empty-state .icon { font-size:3rem; margin-bottom:12px; }
.empty-state h3 { font-family:'Fraunces',serif; font-size:1.1rem; color:var(--muted2); margin-bottom:8px; }
.empty-state p { font-size:0.8rem; }

@media(max-width:900px) { .page-wrap{grid-template-columns:1fr} .sidebar{order:-1} }
@media(max-width:600px) { .header-wrap{padding:0 16px} .page-wrap{padding:16px} .logo-text{font-size:1.1rem} .footer-top{flex-direction:column} }
</style>
</head>
