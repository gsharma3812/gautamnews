<script>
// ── CLOCK ──────────────────────────────────────────────────────
function updateClock() {
  const now = new Date();
  const h = String(now.getHours()).padStart(2,'0');
  const m = String(now.getMinutes()).padStart(2,'0');
  const s = String(now.getSeconds()).padStart(2,'0');
  const clockEl = document.getElementById('clock');
  if (clockEl) clockEl.innerHTML = h + ':' + m + ':<span class="seconds" id="sec">' + s + '</span>';

  const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const dateEl = document.getElementById('dateDisp');
  if (dateEl) dateEl.innerHTML = days[now.getDay()] + '<br>' + now.getDate() + ' ' + months[now.getMonth()] + ' ' + now.getFullYear();

  const hourChip = document.getElementById('curHourChip');
  if (hourChip) {
    const ampm = now.getHours() >= 12 ? 'PM' : 'AM';
    const displayH = now.getHours() % 12 || 12;
    hourChip.textContent = displayH + ':00 ' + ampm;
  }
}
updateClock();
setInterval(updateClock, 1000);

// ── ACTIVE STATE ───────────────────────────────────────────────
let currentCat = 'home';
let currentState = 'National';

// ── CATEGORY TABS ──────────────────────────────────────────────
function switchTab(cat) {
  currentCat = cat;

  // Update tab button styles
  document.querySelectorAll('.cat-tab').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.cat === cat);
  });

  // Show correct section
  document.querySelectorAll('.content-section').forEach(sec => {
    sec.classList.toggle('active', sec.id === 'sec-' + cat);
  });

  // After switching tab, apply current state filter to new section
  applyStateFilter(currentState, false);

  // Scroll to top of main
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

document.querySelectorAll('.cat-tab').forEach(btn => {
  btn.addEventListener('click', () => switchTab(btn.dataset.cat));
});

// ── STATE FILTER ───────────────────────────────────────────────
function applyStateFilter(state, scroll) {
  currentState = state;

  // Update pill styles
  document.querySelectorAll('.state-pill').forEach(pill => {
    pill.classList.toggle('active', pill.dataset.state === state);
  });

  // Filter cards in currently visible section
  const activeSection = document.querySelector('.content-section.active');
  if (!activeSection) return;

  const cards = activeSection.querySelectorAll('.news-card');
  let visibleCount = 0;

  cards.forEach(card => {
    const cardState = card.dataset.state || 'National';
    const show = (state === 'National') || (cardState === state) || (cardState === 'National');
    card.style.display = show ? '' : 'none';
    if (show) visibleCount++;
  });

  // State notice
  const notice = document.getElementById('state-notice-main');
  if (notice) {
    if (state !== 'National') {
      notice.textContent = '📍 Showing news for: ' + state;
      notice.classList.add('show');
    } else {
      notice.classList.remove('show');
    }
  }

  // Empty state
  let emptyEl = activeSection.querySelector('.empty-state');
  if (visibleCount === 0) {
    if (!emptyEl) {
      emptyEl = document.createElement('div');
      emptyEl.className = 'empty-state';
      emptyEl.innerHTML = '<div class="icon">📰</div><h3>No stories found for ' + state + '</h3><p>Switch to 🇮🇳 National for all latest news.</p>';
      activeSection.appendChild(emptyEl);
    }
    emptyEl.style.display = '';
  } else {
    if (emptyEl) emptyEl.style.display = 'none';
  }

  if (scroll) window.scrollTo({ top: 0, behavior: 'smooth' });
}

document.querySelectorAll('.state-pill').forEach(pill => {
  pill.addEventListener('click', () => applyStateFilter(pill.dataset.state, true));
});

// ── NEWSLETTER ─────────────────────────────────────────────────
function subscribeNewsletter() {
  const emailEl = document.getElementById('nl-email');
  const email = emailEl ? emailEl.value.trim() : '';
  const successEl = document.getElementById('nl-success');
  if (!email || !email.includes('@')) {
    if (emailEl) { emailEl.style.borderColor='var(--red)'; setTimeout(()=>emailEl.style.borderColor='',2000); }
    return;
  }
  if (successEl) { successEl.style.display = 'block'; }
  if (emailEl) emailEl.value = '';
}

// ── INIT ───────────────────────────────────────────────────────
// Ensure home tab is active and all state-notice elements are linked
applyStateFilter('National', false);
</script>
